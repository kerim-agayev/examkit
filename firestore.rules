// =============================================================================
// ExamKit — Firestore Security Rules
// Bkz: docs/phase_1/architecture/firebase_schema.md
//       docs/phase_1/secrets_management.md
//
// ÖNEMLİ: Öğrenci tarafı exam_answers/ OKUYAMAZ.
//         Puanlama sadece öğretmen Flutter uygulamasında (ADR-006).
// =============================================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // === Users ===
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId
                    && request.resource.data.name is string;
      allow create: if request.auth != null && request.auth.uid == userId;
      // No delete — users are never removed
    }

    // === Groups ===
    match /groups/{groupId} {
      allow read: if request.auth != null
                   && resource.data.teacherId == request.auth.uid;
      allow create: if request.auth != null
                     && request.resource.data.teacherId == request.auth.uid
                     && request.resource.data.name is string;
      allow update: if request.auth != null
                     && resource.data.teacherId == request.auth.uid;
      allow delete: if request.auth != null
                     && resource.data.teacherId == request.auth.uid
                     && resource.data.examCount == 0;  // Sadece boş grup silinebilir
    }

    // === Exams ===
    match /exams/{examId} {
      // Öğretmen: kendi sınavlarını okuyabilir
      allow read: if request.auth != null
                   && resource.data.ownerTeacherId == request.auth.uid;
      // Öğrenci: code ile sadece draft olmayan sınavları okuyabilir
      allow read: if resource.data.status != 'draft'
                   && resource.data.code == request.query.code;
      allow create: if request.auth != null
                     && request.resource.data.ownerTeacherId == request.auth.uid;
      allow update: if request.auth != null
                     && resource.data.ownerTeacherId == request.auth.uid;
      allow delete: if request.auth != null
                     && resource.data.ownerTeacherId == request.auth.uid
                     && resource.data.status == 'draft';  // Sadece taslak silinebilir
    }

    // === Questions (SORU METNİ — cevap yok) ===
    match /exams/{examId}/questions/{questionId} {
      // Öğretmen: okuyabilir
      allow read: if request.auth != null;
      // Öğrenci: sadece soru metnini okuyabilir (correctOptionId vs YOK)
      allow read: if true;  // Public read — sorular görünür olmalı
      allow create, update, delete: if request.auth != null;
    }

    // === Exam Answers (DOĞRU CEVAPLAR — sadece öğretmen) ===
    match /exams/{examId}/exam_answers/{questionId} {
      // KRİTİK: Sadece auth'lu öğretmen okuyabilir
      allow read, write: if request.auth != null;
      // Öğrenci OKUYAMAZ — bu firewall'ın temel güvenlik garantisidir
    }

    // === Sessions (Öğrenci sınav oturumları) ===
    match /sessions/{sessionId} {
      // Öğretmen: kendi sınavının session'larını okuyabilir
      allow read: if request.auth != null;
      // Öğrenci: kendi session'ını okuyabilir (sessionId bilgisi ile)
      allow read: if true;  // Public-by-ID — öğrenci kendi ID'sini bilir
      allow create: if true;  // Öğrenci session oluşturabilir
      // Öğrenci: kendi session'ına cevap yazabilir (sadece answers alanı)
      allow update: if request.resource.data.diff(resource.data)
                      .affectedKeys().hasOnly(['answers', 'status', 'completedAt']);
      // Öğretmen: score/percentage/rank/scoreCalculatedAt yazabilir (puanlama)
      allow update: if request.auth != null
                     && request.resource.data.diff(resource.data)
                        .affectedKeys().hasAny(['score', 'percentage', 'rank', 'scoreCalculatedAt']);
    }
  }
}
